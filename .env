# FinAlert Backend Configuration
# Copy this file to .env and fill in your API keys

# News API (https://newsapi.org) - Free tier available
newsapi_key=ba0f59cd4c034f7489e4e636e49519aa

# SerpAPI (https://serpapi.com) - For Baidu News & Google News access
# Free tier: 250 searches/month
serpapi_key=d72c3d6f38b9d5b8c831069073d686a8a3129015eb04fd2e3fdbcb453bf16f00

# Baidu API (optional - for direct Baidu access)
baidu_api_key=your_baidu_api_key_here

# Twitter/X Bearer Token (optional - for Twitter news feed)
twitter_bearer_token=your_twitter_bearer_token_here

# Database (SQLite default - no changes needed for local dev)
database_url=sqlite:///./finalert.db

# App Settings
app_name=FinAlert API
debug=false
refresh_interval_minutes=5

# Alert Thresholds
default_sentiment_threshold=0.3
default_impact_threshold=60